{
  "name": "genz212-presidential-elections",
  "version": "1.0.0",
  "description": "Voting dapp for GENZ212 Presidential Elections 2025, built with Hardhat",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:report": "hardhat test --reporter mochawesome",
    "report:open": "ls -t test-results/mochawesome-report_*.html | head -1 | xargs open",
    "report:clean": "rm -rf test-results/",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "frontend": "node serve.js",
    "dev": "concurrently \"npm run node\" \"npm run deploy\" \"npm run frontend\"",
    "start": "npm run dev",
    "stop": "pkill -f 'hardhat node'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:write": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "hardhat": "^2.19.0",
    "mochawesome": "^7.1.4",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "ethers": "^6.8.0"
  }
}
