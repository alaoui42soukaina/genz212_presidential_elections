{
  "name": "genz212-presidential-elections",
  "version": "1.0.0",
  "description": "A minimal voting dapp built with Hardhat",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "frontend": "node serve.js",
    "dev": "concurrently \"npm run node\" \"npm run deploy\" \"npm run frontend\"",
    "start": "npm run dev",
    "stop": "pkill -f 'hardhat node'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.7.2",
    "concurrently": "^9.2.1",
    "hardhat": "^2.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ethers": "^6.8.0"
  }
}
